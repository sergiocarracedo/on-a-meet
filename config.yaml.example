# on-a-meet configuration file
# Place at ~/.config/on-a-meet/config.yaml
# CLI flags override these values.

# Target specific camera device path (e.g., /dev/video0)
# If empty, monitors all cameras with OR logic.
camera: ""

# Polling interval (Go duration format: 500ms, 1s, 2s)
interval: "1s"

# Command to execute when camera turns on
# Supports template variables: {{.CameraID}}, {{.Device}}, {{.State}}
#   {{.CameraID}} — short device name, e.g. "video0"
#   {{.Device}}   — full device path, e.g. "/dev/video0"
#   {{.State}}    — "on" or "off"
on-command: ""

# Command to execute when camera turns off
# Supports same template variables as on-command.
off-command: ""

# Detection method: "v4l2" or "lsof" (future)
detect-method: "v4l2"

# Number of consecutive same-state polls before firing (debounce)
debounce: 3

# Command execution timeout (Go duration format: 10s, 30s, 1m)
# Set to 0 for no timeout (command runs until completion)
timeout: "30s"

# Path to an environment file loaded by systemd when running the service.
# Variables in this file are available to --on / --off commands.
# Example: /etc/default/on-a-meet  or  /etc/sysconfig/on-a-meet
# Only used when installed as a system service.
environment-file: ""
